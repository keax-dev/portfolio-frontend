{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false",
    "test:unit": "ng test --watch=false --exclude=src/**/*.integration.spec.ts",
    "test:integration": "ng test --watch=false --include=src/**/*.integration.spec.ts",
    "test:watch": "ng test --watch",
    "test:coverage": "ng test --watch=false --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "ng lint",
    "typecheck": "npm run typecheck:app && npm run typecheck:tests && npm run typecheck:e2e",
    "typecheck:app": "ngc -p tsconfig.app.json --noEmit",
    "typecheck:tests": "tsc -p tsconfig.spec.json --noEmit",
    "typecheck:e2e": "tsc -p tsconfig.e2e.json --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "private": true,
  "engines": {
    "node": "^22.22.3 || ^24.15.0 || ^26.0.0"
  },
  "dependencies": {
    "@angular/animations": "^22.0.5",
    "@angular/cdk": "^22.0.3",
    "@angular/common": "^22.0.5",
    "@angular/compiler": "^22.0.5",
    "@angular/core": "^22.0.5",
    "@angular/forms": "^22.0.5",
    "@angular/platform-browser": "^22.0.5",
    "@angular/router": "^22.0.5",
    "bootstrap": "^5.3.8",
    "ngx-spinner": "^21.1.0",
    "primeicons": "^7.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular/build": "^22.0.5",
    "@angular/cli": "^22.0.5",
    "@angular/compiler-cli": "^22.0.5",
    "@angular/platform-browser-dynamic": "^22.0.5",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.9",
    "angular-eslint": "^22.0.0",
    "baseline-browser-mapping": "^2.8.32",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^27.4.0",
    "prettier": "^3.9.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
